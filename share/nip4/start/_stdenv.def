/* One image in, one out.
 */
system_image command x
    = oo_unary_function system_image_op x, is_class x
    = system x, is_image x
    = error_bad_args "system_image" ["[char]", "Image"] [command, x]
{
    system_image_op = Operator "system_image" (system_image command)
        Operator_type.COMPOUND_REWRAP false;

    system im
        = image_out
    {
        [image_out, log] = vips_system [
             $in => [im],
             $out => true,
             $in_format => "%s.tif",
             $out_format => "%s.tif",
             $cache => true,
             $log => true
        ] command;
    }
}

/* Two images in, one out.
 */
system_image2 command x1 x2
    = oo_binary_function system_image2_op x1 x2, is_class x1
    = oo_binary'_function system_image2_op x1 x2, is_class x2
    = system x1 x2, is_image x1 && is_image x2
    = error_bad_args "system_image2"
        ["[char]", "Image", "Image"] [command, x1, x2]
{
    system_image2_op = Operator "system_image2" (system_image2 command)
        Operator_type.COMPOUND_REWRAP false;

    system x1 x2
        = vips_system [
            $in => [x1, x2],
            $out => true,
            $in_format => "%s.tif",
            $out_format => "%s.tif",
            $cache => true
        ] command;
}

/* Three images in, one out.
 */
system_image3 command x1 x2 x3
    = oo_binary_function system_image2_op x2 x3, is_class x2
    = oo_binary'_function system_image2_op x2 x3, is_class x3
    = system x1 x2 x3, is_image x1 && is_image x2 && is_image x3
    = error_bad_args "system_image3"
        ["[char]", "Image", "Image", "Image"] [command, x1, x2, x3]
{
    system_image2_op = Operator "system_image2" (system_image3 command x1)
        Operator_type.COMPOUND_REWRAP false;

    system x1 x2 x3
        = vips_system [
            $in => [x1, x2, x3],
            $out => true,
            $in_format => "%s.tif",
            $out_format => "%s.tif",
            $cache => true
        ] command;
}

/* Zero images in, one out.
 */
system_image0 command
    = Image image_out
{
    image_out = vips_system [
        $out => true,
        $out_format => "%s.tif",
        $cache => true
    ] command;
}

