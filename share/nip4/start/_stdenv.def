Fourier = class {
    Sense = class Enum {
        PASS = 0;
        REJECT = 1;

        _description = [
            [PASS, "Pass"],
            [REJECT, "Reject"]
        ];
    }

    Type = class Enum {
        IDEAL = 0;
        GAUSSIAN = 1;
        BUTTERWORTH = 2;

        _description = [
            [IDEAL, "Ideal"],
            [GAUSSIAN, "Gaussian"],
            [BUTTERWORTH, "Butterworth"]
        ];
    }

    Order = class Enum {
        HIGH_LOW = 0;
        RING = 1;
        BAND = 2;

        _description = [
            [HIGH_LOW, "High/low"],
            [RING, "Ring"],
            [BAND, "Band"]
        ];
    }

    options sense = [$reject => sense == Sense.REJECT];

    // func to make a visualisation image
    visualise
        = Image @ set_header $interpretation $fourier @ rotquad;

    // use a mask generation function to filter an image
    process mask_generator image
        = Image (set_header $interpretation interpretation
            (vips_freqmult [] image mask))
    {
        interpretation = get_interpretation image;
        width = get_width image;
        height = get_height image;
        mask = mask_generator width height;
    }

    Ideal = class {
        High_low default_sense = class {
            _vislevel = 2;

            sense = Sense.picker default_sense;
            fc = Scale "Frequency cutoff" 0.01 0.99 0.5;

            _generate width height
                = vips_mask_ideal (options sense) width height
                    fc.value;
        }

        Ring default_sense = class {
            _vislevel = 2;

            sense = Sense.picker default_sense;
            fc = Scale "Frequency cutoff" 0.01 0.99 0.5;
            rw = Scale "Ring width" 0.01 0.99 0.5;

            _generate width height
                = vips_mask_ideal_ring (options sense) width height
                    fc.value rw.value;
        }

        Band default_sense = class {
            _vislevel = 2;

            sense = Sense.picker default_sense;
            fcx = Scale "Horizontal frequency cutoff" 0.01 0.99 0.5;
            fcy = Scale "Vertical frequency cutoff" 0.01 0.99 0.5;
            r = Scale "Radius" 0.01 0.99 0.5;

            _generate width height
                = vips_mask_ideal_band (options sense) width height
                    fcx.value fcy.value r.value;
        }
    }

    Gaussian = class {
        High_low default_sense = class {
            _vislevel = 2;

            sense = Sense.picker default_sense;
            fc = Scale "Frequency cutoff" 0.01 0.99 0.5;
            ac = Scale "Amplitude cutoff" 0.01 0.99 0.5;

            _generate width height
                = vips_mask_gaussian (options sense) width height
                    fc.value ac.value;
        }

        Ring default_sense = class {
            _vislevel = 2;

            sense = Sense.picker default_sense;
            fc = Scale "Frequency cutoff" 0.01 0.99 0.5;
            ac = Scale "Amplitude cutoff" 0.01 0.99 0.5;
            rw = Scale "Ring width" 0.01 0.99 0.5;

            _generate width height
                = vips_mask_gaussian_ring (options sense) width height
                    fc.value rw.value ac.value;
        }

        Band default_sense = class {
            _vislevel = 2;

            sense = Sense.picker default_sense;
            fcx = Scale "Horizontal frequency cutoff" 0.01 0.99 0.5;
            fcy = Scale "Vertical frequency cutoff" 0.01 0.99 0.5;
            r = Scale "Radius" 0.01 0.99 0.5;
            ac = Scale "Amplitude cutoff" 0.01 0.99 0.5;

            _generate width height
                = vips_mask_gaussian_band (options sense) width height
                    fcx.value fcy.value r.value ac.value;
        }
    }

    Butterworth = class {
        High_low default_sense = class {
            _vislevel = 2;

            sense = Sense.picker default_sense;
            fc = Scale "Frequency cutoff" 0.01 0.99 0.5;
            ac = Scale "Amplitude cutoff" 0.01 0.99 0.5;
            o = Scale "Order" 1 10 2;

            _generate width height
                = vips_mask_butterworth (options sense) width height
                    o.value fc.value ac.value;
        }

        Ring default_sense = class {
            _vislevel = 2;

            sense = Sense.picker default_sense;
            fc = Scale "Frequency cutoff" 0.01 0.99 0.5;
            ac = Scale "Amplitude cutoff" 0.01 0.99 0.5;
            rw = Scale "Ring width" 0.01 0.99 0.5;
            o = Scale "Order" 1 10 2;

            _generate width height
                = vips_mask_butterworth_ring (options sense) width height
                    o.value fc.value rw.value ac.value;
        }

        Band default_sense = class {
            _vislevel = 2;

            sense = Sense.picker default_sense;
            fcx = Scale "Horizontal frequency cutoff" 0.01 0.99 0.5;
            fcy = Scale "Vertical frequency cutoff" 0.01 0.99 0.5;
            r = Scale "Radius" 0.01 0.99 0.5;
            ac = Scale "Amplitude cutoff" 0.01 0.99 0.5;
            o = Scale "Order" 1 10 2;

            _generate width height
                = vips_mask_butterworth_band (options sense) width height
                    o.value fcx.value fcy.value r.value ac.value;
        }
    }
}

Text rgba message = class {
    _vislevel = 2;

    text = String "Text to paint" message;
    font = Fontname "Use font" Workspaces.Preferences.PAINTBOX_FONT;
    align = Align.picker $LOW;
    dpi = Expression "DPI" 500;
    spacing = Expression "Line spacing" 1;
    wrap = Toggle "Wrap lines on character boundaries" false;
    justify = Toggle "Justify" false;
    autodpi = Toggle "Fit text within width and height" false;

    _generate width height = vips_text [
        $font => font.value,
        $width => width,
        $height => height,
        $align => align.value_key,
        $justify => justify.value,
        $dpi => if autodpi then 0 else to_real dpi,
        $spacing => to_real spacing,
        $rgba => rgba,
        $wrap => wrap.value
      ] text.value;
}
