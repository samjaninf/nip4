            "real", "real", "real", "real", "real", "real", "real", "real",
            "Image|image", "Image|image"]
        [options, direction, xr1, yr1, xs1, ys1, xr2, yr2, xs2, ys2, a, b]
{
    mosaic1_op = Operator "mosaic" (mosaic1 options direction xr1 yr1 xs1 ys1 xr2 yr2 xs2 ys2)
        Operator_type.COMPOUND_REWRAP false;
}

globalbalance options x
    = oo_unary_function globalbalance_op x, is_class x
