colourspace options to in
    = oo_unary_function colourspace_op in, is_class in
    = mat1 (colourspace options to) in, is_matrix in
    = vips_colourspace options in (to_enum to), is_image in
    = error_bad_args "colourspace"
        ["[option]", "Interpretation", "Image|Matrix|Vector"] [options, to, in]
{
    colourspace_op = Operator "colourspace" (colourspace options to)
        Operator_type.COMPOUND_REWRAP false;

    mat1 fn = get_value @
        vips_matrix_from_image @
        bandunfold [] @ fn @
        set_header $interpretation $multiband @
        bandfold [] @
        vips_image_from_matrix @
        Matrix;
}

