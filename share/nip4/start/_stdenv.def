        Operator_type.COMPOUND_REWRAP false;

    sobel_im = vips_sobel [];
}

prewitt x
    = oo_unary_function prewitt_op x, is_class x
    = prewitt_im x, is_image x
    = error_bad_args "prewitt" ["Image"] [x]
{
    prewitt_op = Operator "prewitt" prewitt
        Operator_type.COMPOUND_REWRAP false;

    prewitt_im = vips_prewitt [];
}

scharr x
    = oo_unary_function scharr_op x, is_class x
    = scharr_im x, is_image x
    = error_bad_args "scharr" ["Image"] [x]
{
    scharr_op = Operator "scharr" scharr
        Operator_type.COMPOUND_REWRAP false;

    scharr_im = vips_scharr [];
