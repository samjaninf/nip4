        (to_real width) (to_real height) (to_real dimension);

/* simple unit tester ... use with eg.
 *
 * main = unit_test [
 *    [true != false, "bool comparison"],
 *    [1 != 2, "int comparison"]
 * ];
 *
 */
unit_test test_list
     = body ++ footer
{
    body
        = concat (map print_list test_list), list
        = map (const '.') pass ++ "\n";

    footer
        = "\ntests failed:\n" ++
            concat (map print_fail fail) ++
            error "abort", len fail > 0
        = [];

    list = any (map (member ["--list", "-L"]) argv);

    split fn l
        = foldr split_item [[], []] l
    {
        split_item x [pass, fail]
            = [pass', fail']
        {
            pass'
                = x : pass, fn x
                = pass;
            fail'
                = x : fail, !fn x
                = fail;
        }
    }

    [pass, fail] = split (extract 0) test_list;
    print_fail [pass, fail] = "FAIL: " ++ fail ++ "\n";

    print_list [test, name]
        = name ++ ": " ++ label ++ "\n"
    {
        label
            = "ok", test
            = "FAIL";
    }
}

bandfold options in
