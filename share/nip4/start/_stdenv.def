// Given a xywh rect, flip it around so wh are always positive
rect_normalise x y w h
    = [x', y', w', h']
{
    x'
        = x + w, w < 0
        = x;
    y'
        = y + h, h < 0
        = y;
    w' = abs w;
    h' = abs h;
}

draw_flood options x y ink image
    = oo_unary_function draw_flood_op image, is_class image
    = vips_draw_flood options
        image (to_vector ink).value (to_real x) (to_real y), is_image image
    = error_bad_args "draw_flood"
        ["[option]", "real", "real", "Vector", "Image"]
        [options, x, y, ink, image]
{
    draw_flood_op = Operator "draw_flood" (draw_flood options x y ink)
        Operator_type.COMPOUND_REWRAP false;
}

/* This version of draw_rect uses insert and should be fast, even for
 * huge images.
 */
draw_rect options x y w h ink image
    = oo_unary_function draw_rect_op image, is_class image
    = my_draw_rect, is_image image
    = error_bad_args "draw_rect"
        ["[option]", "real", "real", "real", "real", "Vector", "Image"]
        [options, x, y, w, h, ink, image]
{
    draw_rect_op = Operator "draw_rect"
        (draw_rect options x y w h ink) Operator_type.COMPOUND_REWRAP false;

    [x', y', w', h'] = rect_normalise
        (to_real x) (to_real y) (to_real w) (to_real h);
    ink' = (to_vector ink).value;
    option = get_option options [
        $fill => false,
        $thickness => 1
    ];
    f = to_bool (option $fill);
    t = to_int (option $thickness);

    my_draw_rect
        = insert [] x' y' (block w' h') image, f
        = (insert [] x' y' (block w' t) @
           insert [] (x' + w' - t) y' (block t h') @
           insert [] x' (y' + h' - t) (block w' t) @
           insert [] x' y' (block t h')) image
    {
        block w h = image_new_from_image [$pixel => ink'] image w h;
    }
}

/* This version of draw_rect uses the paintbox rect draw operation. It is an
 * inplace operation and will use bucketloads of memory.
 */
draw_rect_paintbox options x y w h ink image
    = oo_unary_function draw_rect_paintbox_op image, is_class image
    = vips_draw_rect options image (to_vector ink).value
        (to_real x) (to_real y) (to_real w) (to_real h), is_image image
    = error_bad_args "draw_rect_paintbox"
        ["[option]", "real", "real", "real", "real", "Vector", "Image"]
        [options, x, y, w, h, ink, image]
{
    draw_rect_paintbox_op = Operator "draw_rect_paintbox"
        (draw_rect_paintbox options x y w h ink)
        Operator_type.COMPOUND_REWRAP false;
}

