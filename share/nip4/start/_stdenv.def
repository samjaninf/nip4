    = oo_binary'_function mosaic1_op a b, is_class b
    = vips_mosaic1 options a b direction xr1 yr1 xs1 ys1 xr2 yr2 xs2 ys2,
        is_image a && is_image b
    = error_bad_args "mosaic1"
