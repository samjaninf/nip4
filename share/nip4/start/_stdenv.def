        (to_real x1) (to_real y1) (to_real x2) (to_real y2), is_image image
    = error_bad_args "draw_line"
        ["[option]", "real", "real", "real", "real", "Vector", "Image"]
        [options, x1, y1, x2, y2, ink, image]
{
