minpair a b
    = oo_binary_function minpair_op a b, is_class a
    = oo_binary'_function minpair_op a b, is_class b
    = minpair_im a b, has_image a && has_image b
    = a, a < b
    = b
{
    minpair_op = Operator "minpair" minpair Operator_type.ARITHMETIC false;

    minpair_im a b = vips_minpair [] (get_image a) (get_image b);
}

maxpair a b
    = oo_binary_function maxpair_op a b, is_class a
    = oo_binary'_function maxpair_op a b, is_class b
    = maxpair_im a b, has_image a && has_image b
    = a, a > b
    = b
{
    maxpair_op = Operator "maxpair" maxpair Operator_type.ARITHMETIC false;

    maxpair_im a b = vips_maxpair [] (get_image a) (get_image b);
}

clamp min max x
    = oo_unary_function clamp_op x, is_class x
    = clamp_im min max x, has_image x
    = max, x > max
    = min, x < min
    = x
{
    clamp_op = Operator "clamp" (clamp min max)
        Operator_type.ARITHMETIC false;

    clamp_im min max x = vips_clamp [
        $min => to_real min,
        $max => to_real max
    ] (get_image x);
}

switch tests
    = oo_unary_function switch_op tests, is_class tests
    = vips_switch [] tests, is_image_list tests
    = switch_wrapped tests, is_list tests
    = bad_args
{
    switch_op = Operator "switch" switch
        Operator_type.COMPOUND_REWRAP false;

    switch_wrapped l
        = Image (switch l'), all (map is_image l')
        = bad_args
    {
        unwrap x
            = get_image x, has_image x
            = x;

        l' = map unwrap l;
    }

    bad_args = error_bad_args "switch" ["[Image]"] [tests];
}

case index cases
    = oo_binary_function case_op index cases, is_class index
    = oo_binary'_function case_op index cases, is_class cases
    = vips_case [] index cases', is_image index && is_image_list cases
    = case_wrapped index cases, is_list cases
    = bad_args
{
    case_op = Operator "case" case Operator_type.COMPOUND_REWRAP false;

    // expand constants in cases list ... take width/height from the
    // first image in ([index] ++ cases)

    objects = [index] ++ cases;
    target_width = get_member_list has_width get_width objects;
    target_height = get_member_list has_height get_height objects;
    target_bands = get_member_list has_bands get_bands objects;
    target_format = get_member_list has_format get_format objects;

    to_image x
        = to_image_size target_width target_height target_bands target_format x;

    expand x
        = to_image x, not (is_image x)
        = x;

    cases' = map expand cases;

    // cases is a list ... unwrap any Image objects in the list, expand any
    // constants, and recurse
    case_wrapped index cases
        = Image (case index cases'), all (map is_image cases')
        = bad_args
    {
        cases' = map (expand @ unwrap) cases;

        unwrap x
            = get_image x, has_image x
            = x;
    }

    bad_args = error_bad_args "case"
        ["Image", "[Image|constant]"] [index, cases];
}

fill_nearest x
    = oo_unary_function nearest_op x, is_class x
    = near x, is_image x
    = error_bad_args "fill_nearest" ["Image"] [x]
{
    nearest_op = Operator "fill_nearest"
        fill_nearest Operator_type.COMPOUND_REWRAP false;

    near x
        = [out, distance]
    {
          [out, distance] = vips_fill_nearest [$distance => true] x;
    }
}

linear options a b x
    = oo_unary_function linear_op x, is_class x
    = vips_linear options (get_image x) (to_real_list a) (to_real_list b),
        has_image x
    = a * x + b
{
    linear_op = Operator "linear" (linear options a b)
        Operator_type.ARITHMETIC false;

    to_real_list x = (to_vector x).value;
}

sdf options width height shape
