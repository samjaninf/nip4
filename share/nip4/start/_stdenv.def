/* optional args to functions
 */

get_option options defaults f
    = error (_ "unknown parameter " ++ f), hits == []
    = hits?0
{
    hits = [v :: [n, v] <- options ++ defaults; n == f];
}

/* Various operators as functions.
 */

logical_and a b = a && b;
logical_or a b = a || b;
bitwise_and a b = a & b;
bitwise_or a b = a | b;
eor a b = a ^ b;
left_shift a b = a << b;
right_shift a b = a >> b;
not a = !a;

less a b = a < b;
less_equal a b = a <= b;
more a b = a > b;
more_equal a b = a >= b;
equal a b = a == b;
not_equal a b = a != b;
pointer_equal a b = a === b;
pointer_not_equal a b = a !== b;

add a b = a + b;
subtract a b = a - b;
multiply a b = a * b;
divide a b = a / b;
idivide a b = (int) ((int) a / (int) b);
power a b = a ** b;
square x = x * x;
remainder a b = a % b;

cons a b = a : b;
dot a b = a . ( b );
join a b = a ++ b;

// 'difference' is defined in _list
subscript a b = a ? b;

generate s n f = [s, n .. f];
comma r i = (r, i);

compose f g = f @ g;

// our only trinary operator is actually a binary operator
if_then_else a x = if a then x?0 else x?1;

cast_unsigned_char x = (unsigned char) x;
cast_signed_char x = (signed char) x;
cast_unsigned_short x = (unsigned short) x;
cast_signed_short x = (signed short) x;
cast_unsigned_int x = (unsigned int) x;
cast_signed_int x = (signed int) x;
cast_float x = (float) x;
cast_double x = (double) x;
cast_complex x = (complex) x;
cast_double_complex x = (double complex) x;

unary_minus x = -x;
negate x = !x;
complement x = ~x;
unary_plus x = +x;

// the vector ops ... im is an image, vec is a real_list
vec op_name im vec
    = vips_linear [] im ones vec,
        op_name == "add" || op_name == "add'"
    = vips_linear [] (-1 * im) ones vec,
        op_name == "subtract'"
    = vips_linear [] im ones inv,
        op_name == "subtract"
    = vips_linear [] im vec zeros,
        op_name == "multiply" || op_name == "multiply'"
    = vips_linear [] (1 / im) vec zeros,
        op_name == "divide'"
    = vips_linear [] im recip zeros,
        op_name == "divide"
    = vips_math2_const [] im "pow" vec,
        op_name == "power"
    = vips_math2_const [] im "wop" vec,
        op_name == "power'"
    = vips_remainder_const [] im vec,
        op_name == "remainder"
    = vips_boolean_const [] im "and" vec,
        op_name == "bitwise_and" || op_name == "bitwise_and'"
    = vips_boolean_const [] im "or" vec,
        op_name == "bitwise_or" || op_name == "bitwise_or'"
    = vips_boolean_const [] im "eor" vec,
        op_name == "eor" || op_name == "eor'"
    = vips_relational_const [] im "equal" vec,
        op_name == "equal" || op_name == "equal'"
    = vips_relational_const [] im "noteq" vec,
        op_name == "not_equal" || op_name == "not_equal'"
    = vips_relational_const [] im "less" vec,
        op_name == "less"
    = vips_relational_const [] im "more" vec,
        op_name == "less'"
    = vips_relational_const [] im "lesseq" vec,
        op_name == "less_equal"
    = vips_relational_const [] im "moreeq" vec,
        op_name == "less_equal'"
    = vips_bandjoin_const [] im vec,
        op_name == "join"
    = error ("unimplemented vector operation: " ++ op_name)
{
    zeros = replicate (len vec) 0;
    ones = replicate (len vec) 1;
    recip = map (divide 1) vec;
    inv = map (multiply (-1)) vec;
}

// make a name value pair ... called from nip4 for => operator
mknvpair n v
    = [n, v], is_string n
    = error "not [char] on LHS of =>";

error_bad_args name types args
    = error (
        _ "bad arguments to" ++ " \"" ++ name ++ "\"\n" ++
        _ "expected" ++ ":\n" ++
        concat (map (\type "\t" ++ type ++ "\n") types) ++
        _ "you passed" ++ ":\n" ++
        concat (map (\arg "\t" ++ print arg ++ "\n") args)
    );

bandsplit x
    = oo_unary_function bandsplit_op x, is_class x
    = map (subscript x) [0 .. bands - 1], is_image x
    = error_bad_args "bandsplit" ["Image"] [x]
{
    bands = get_header "bands" x;
    bandsplit_op = Operator "bandsplit" (map Image @ bandsplit)
        Operator_type.COMPOUND false;
}

bandjoin l
    = wrapper joined, has_wrapper
    = joined, is_listof has_image l
    = error_bad_args "bandjoin" ["[Image]"] [l]
{
    has_wrapper = has_member_list (has_member "Image") l;
    wrapper = get_member_list (has_member "Image") (get_member "Image") l;
    joined = vips_bandjoin [] (map get_image l);
}

bandjoin_const c x
    = oo_unary_function bandjoin_const_op x, is_class x
    = vips_bandjoin_const [] x (to_vector c).value, is_image x
    = error_bad_args "bandjoin_const" ["Vector", "[Image]"] [c, x]
{
    bandjoin_const_op = Operator "bandjoin_const" (bandjoin_const c)
        Operator_type.COMPOUND_REWRAP false;
}

bandbool op x
    = oo_unary_function bandbool_op x, is_class x
    = vips_bandbool [] x (to_enum op), is_image x
    = error_bad_args "bandbool" ["OperationBoolean", "[Image]"] [op, x]
{
    bandbool_op = Operator "bandbool" (bandbool op)
        Operator_type.COMPOUND_REWRAP false;
}

bandand = bandbool "and";
bandor = bandbool "or";
bandeor = bandbool "eor";

sum x
    = oo_unary_function sum_op x, is_class x
    // don't use "mean" here, it'd create a circular dependency
    = vips_avg [] x * get_width x * get_height x * get_bands x, is_image x
    = sum_list x, is_list x
    = error_bad_args "sum" ["Image|Vector"] [x]
{
    sum_op = Operator "sum" sum Operator_type.COMPOUND false;

    // add elements in a nested-list thing
    sum_list l
        = foldr acc 0 l
    {
        acc x total
            = total + sum x, is_list x
            = total + x;
    }
}

product x
    = oo_unary_function product_op x, is_class x
    = product_list x, is_list x
    // (product image) doesn't make much sense :(
    = error_bad_args "product" ["Image|Vector"] [x]
{
    product_op = Operator "product" product Operator_type.COMPOUND false;

    product_list l
        = foldr prod 1 l
    {
        prod x total
            = total * product x, is_list x
            = total * x;
    }
}

mean x
    = oo_unary_function mean_op x, is_class x
    = vips_avg [] x, is_image x
    = mean_list x, is_list x
    = error_bad_args "mean" ["Image|Vector"] [x]
{
    mean_op = Operator "mean" mean Operator_type.COMPOUND false;

    mean_list l = sum l / size l;

    // number of elements in some sort of nested-list thing
    size l
        = foldr acc 0 l
    {
        acc x total
            = total + size x, is_list x
            = total + 1;
    }
}

// geometric mean
meang x
    = (appl (power e) @ mean @ appl log) x
{
    appl fn x
        = map fn x, is_list x
        = fn x;
}

skew x
    = oo_unary_function skew_op x, is_class x
    = sum ((x - m) ** 3) / ((N - 1) * s ** 3), is_image x
    = sum ((Group x' - m) ** 3).value / ((N - 1) * s ** 3), is_list x
    = error_bad_args "skew" ["Image|Vector"] [x]
{
    skew_op = Operator "skew" skew Operator_type.COMPOUND false;

    // squash any large matrix down to a flat list ... much simpler
    x'
        = x, is_image x;
        = flatten x;

    m = mean x';
    s = deviation x';
    w = get_width x';
    h = get_height x';
    b = get_bands x';

    N
        = w * h * b, is_image x'
        = len x';
}

kurtosis x
    = oo_unary_function kurtosis_op x, is_class x
    = sum ((x - m) ** 4) / ((N - 1) * s ** 4), is_image x
    = sum ((Group x' - m) ** 4).value / ((N - 1) * s ** 4), is_list x
    = error_bad_args "kurtosis" ["Image|Vector"] [x]
{
    kurtosis_op = Operator "kurtosis" kurtosis Operator_type.COMPOUND false;

    // squash any large matrix down to a flat list ... much simpler
    x'
        = x, is_image x;
        = flatten x;

    m = mean x';
    s = deviation x';
    w = get_width x';
    h = get_height x';
    b = get_bands x';

    N
        = len x', is_list x';
        = w * h * b;
}

// zero-excluding mean
meanze x
    = oo_unary_function meanze_op x, is_class x
    = meanze_image_hist x, is_image x &&
        (fmt == Format.UCHAR || fmt == Format.USHORT)
    = meanze_image x, is_image x
    = meanze_list x, is_list x
    = error_bad_args "meanze" ["Image|Vector"] [x]
{
    fmt = get_format x;

    meanze_op = Operator "meanze" meanze Operator_type.COMPOUND false;

    meanze_list l = sum l / size l;

    // number of non-zero elements in some sort of nested-list thing
    size l
        = foldr acc 0 l
    {
        acc x total
            = total + size x, is_list x
            = total + 1, x != 0;
            = total;
    }

    // add elements in a nested-list thing
    sum l
        = foldr acc 0 l
    {
        acc x total
            = total + sum x, is_list x
            = total + x;
    }

    // image mean, for any image type
    meanze_image i
        = sum / N
    {
        w = get_width i;
        h = get_height i;
        b = get_bands i;

        st = stats i;
        sum = st.value?0?2;

        // find non-zero pixels (not zero in all bands)
        zp = vec "not_equal" i (replicate b 0);

        // number of non-zero pixels
        N = b * (mean zp * w * h) / 255;
    }

    // image mean for 8 and 16-bit unsigned images
    // we can use a histogram, yay, and save a pass through the image
    meanze_image_hist i
        = sum / N
    {
        // histogram, knock out zeros
        hist = hist_find i;
        black = image_new_from_image [] hist 1 1;
        histze = insert [] 0 0 black hist;

        // matching identity
        iden = vips_identity [
            $bands => get_bands hist,
            $ushort => get_width hist > 256,
            $size => get_width hist
        ];

        // number of non-zero pixels
        N = mean histze * 256;

        // sum of pixels
        sum = mean (hist * iden) * 256;
    }
}

deviation x
    = oo_unary_function deviation_op x, is_class x
    = vips_deviate [] x, is_image x
    = deviation_list x, is_real_list x || is_matrix x
    = error_bad_args "deviation" ["Image|Vector|Matrix"] [x]
{
    deviation_op = Operator "deviation" deviation
        Operator_type.COMPOUND false;

    deviation_list l
        = (abs (s2 - (s * s / n)) / (n - 1)) ** 0.5
    {
        [n, s, s2] = sum_sum2_list l;
    }

    // return n, sum, sum of squares for a list of reals
    sum_sum2_list x
        = foldr accumulate [0, 0, 0] x
    {
        accumulate x sofar
            = [n + 1, x + s, x * x + s2], is_real x
            = [n + n', s + s', s2 + s2'], is_list x
            = error "sum_sum2_list: not real or [real]"
        {
            [n, s, s2] = sofar;
            [n', s', s2'] = sum_sum2_list x;
        }
    }
}

deviationze x
    = oo_unary_function deviationze_op x, is_class x
    = deviationze_image x, is_image x
    = deviationze_list x, is_real_list x || is_matrix x
    = error_bad_args "deviationze" ["Image|Vector"] [x]
{
    deviationze_op = Operator "deviationze" deviationze
        Operator_type.COMPOUND false;

    deviationze_list l
        = (abs (s2 - (s * s / n)) / (n - 1)) ** 0.5
    {
        [n, s, s2] = sum_sum2_list l;
    }

    // return number of non-zero elements, sum, sum of squares for a list of
    // reals
    sum_sum2_list x
        = foldr accumulate [0, 0, 0] x
    {
        accumulate x sofar
            = sofar, is_real x && x == 0
            = [n + 1, x + s, x * x + s2], is_real x
            = [n + n', s + s', s2 + s2'], is_list x
            = error "sum_sum2_list: not real or [real]"
        {
            [n, s, s2] = sofar;
            [n', s', s2'] = sum_sum2_list x;
        }
    }

    deviationze_image i
        = ((sum2 - sum * sum / N) / (N - 1)) ** 0.5
    {
        w = get_width i;
        h = get_height i;
        b = get_bands i;

        st = stats i;
        sum = st.value?0?2;
        sum2 = st.value?0?3;

        // find non-zero pixels (not zero in all bands)
        zp = vec "not_equal" i (replicate b 0);

        // number of non-zero pixels
        N = b * (mean zp * w * h) / 255;
    }
}

// find the centre of gravity of a histogram
gravity x
    = oo_unary_function gravity_op x, is_class x
    = gravity_hist x, is_hist x
    = gravity_list x, is_list x
    = error_bad_args "gravity" ["Image|Vector"] [x]
{
    gravity_op = Operator "gravity" gravity Operator_type.COMPOUND false;

    // centre of gravity of a histogram... use the histogram to weight an
    // identity, then sum, then find the mean element
    gravity_hist h
        = m
    {
        // make horizontal
        h'
            = rot270 h, get_width h == 1
            = h, get_height h == 1
            = error "width or height not 1";

        // number of elements
        w = get_width h';

        // matching identity
        i
            = vips_identity [$ushort => true, $size => w], w <= 2 ** 16 - 1
            = (xyz [] w 1) ? 0;

        // weight identity and sum
        s = mean (i * h') * w;

        // sum of original histogram
        s' = mean h * w;

        // weighted mean
        m = s / s';
    }

    gravity_list l
        = m
    {
        w = len l;

        // matching identity
        i = [0, 1 .. w - 1];

        // weight identity and sum
        s = sum (map2 multiply i l);

        // sum of original histogram
        s' = sum l;

        // weighted mean
        m = s / s';
    }
}

project x
    = oo_unary_function project_op x, is_class x
    = vips_project [] x, is_image x
    = error_bad_args "project" ["Image"] [x]
{
    project_op = Operator "project" project Operator_type.COMPOUND false;
}

abs x
    = oo_unary_function abs_op x, is_class x
    = vips_abs [] x, is_image x
    = abs_cmplx x, is_complex x
    = abs_num x, is_real x
    = abs_list x, is_real_list x
    = abs_list (map abs_list x), is_matrix x
    = error_bad_args "abs" ["Image|Vector|complex"] [x]
{
    abs_op = Operator "abs" abs Operator_type.COMPOUND false;

    abs_list l = (sum (map square l)) ** 0.5;

    abs_num n
        = n, n >= 0
        = -n;

    abs_cmplx c = ((re c) ** 2 + (im c) ** 2) ** 0.5;
}

// like abs, but treat pixels as vectors ... ie. always get a 1-band image
// back ... also treat matricies as lists of vectors
// handy for dE from object difference
abs_vec x
    = oo_unary_function abs_vec_op x, is_class x
    = abs_vec_image x, is_image x
    = abs_vec_cmplx x, is_complex x
    = abs_vec_num x, is_real x
    = abs_vec_list x, is_real_list x
    = mean (map abs_vec_list x), is_matrix x
    = error_bad_args "abs_vec" ["Image|Vector"] [x]
{
    abs_vec_op = Operator "abs_vec" abs_vec
        Operator_type.COMPOUND false;

    abs_vec_list l = (sum (map square l)) ** 0.5;

    abs_vec_num n
        = n, n >= 0
        = -n;

    abs_vec_cmplx c = ((re c) ** 2 + (im c) ** 2) ** 0.5;

    abs_vec_image im = (sum (map square (bandsplit im))) ** 0.5;
}

copy options x
    = oo_unary_function copy_op x, is_class x
    = vips_copy options x, is_image x
    = x
{
    copy_op = Operator "copy" (copy options)
        Operator_type.COMPOUND_REWRAP false;
}

// apply an image function to a [[real]] ... matrix is converted to a 1 band
// image for processing
apply_matrix_as_image fn
    = get_value @ vips_matrix_from_image @ fn @ vips_image_from_matrix @ Matrix;

// a general image/matrix operation where the mat version is most easily done
// by converting mat -> image -> mat
apply_matim_operation name fn in
    = oo_unary_function class_op in, is_class in
    = fn in, is_image in
    = apply_matrix_as_image fn in, is_matrix in
    = error_bad_args name ["Image|Matrix"] [x]
{
    class_op = Operator name (apply_matim_operation name fn)
        Operator_type.COMPOUND_REWRAP false;
}

rot45 = apply_matim_operation "rot45" (vips_rot45 []);
rot90 = apply_matim_operation "rot90" (converse (vips_rot []) "d90");
rot180 = apply_matim_operation "rot180" (converse (vips_rot []) "d180");
rot270 = apply_matim_operation "rot270" (converse (vips_rot []) "d270");
rotquad in = apply_matim_operation "rotquad" (vips_wrap [
    $x => get_width in / 2,
    $y => get_height in / 2
]) in;
fliplr = apply_matim_operation "fliplr" (converse (vips_flip []) "horizontal");
fliptb = apply_matim_operation "flipud" (converse (vips_flip []) "vertical");
matinv = apply_matim_operation "matinv" (vips_matrixinvert []);

transpose x
    = oo_unary_function transpose_op x, is_class x
    = transpose_image x, is_image x
    = transpose_list x, is_listof is_list x
    = error_bad_args "transpose" ["Image|Matrix"] [x]
{
    transpose_op = Operator "transpose"
        transpose Operator_type.COMPOUND_REWRAP false;

    transpose_list l
        = [], l' == []
        = (map hd l') : (transpose_list (map tl l'))
    {
        l' = takewhile (not_equal []) l;
    }

    transpose_image = fliptb @ rot270;
}

apply_matim_binary fn a b
    = itom (fn (mtoi a) (mtoi b))
{
    itom x = (vips_matrix_from_image x).value;
    mtoi x
        = vips_image_from_matrix (Matrix x), is_matrix x
        = x;
}

matmul a b
    = oo_binary'_function matmul_op a b, is_class b
    = oo_binary_function matmul_op a b, is_class a
    = apply_matim_binary (vips_matrixmultiply []) a b,
        is_matrix_image a && is_matrix_image b
    = error_bad_args "matmul"
        ["Image|image|Matrix", "Image|Matrix"] [a, b]
{
    matmul_op = Operator "matmul" matmul Operator_type.COMPOUND_REWRAP false;
}

cache tile_width tile_height max_tiles x
    = oo_unary_function cache_op x, is_class x
    = vips_tilecache [
        $tile_width => to_real tile_width,
        $tile_height => to_real tile_height,
        $max_tiles => to_real max_tiles,
        $access => "random",
        $persistent => true,
        $threaded => true
      ] x, is_image x
    = error_bad_args "cache"
        ["real", "real", "real", "Image"]
        [tile_width, tile_height, max_tiles, x]
{
    cache_op = Operator "cache" (cache tile_width tile_height max_tiles)
        Operator_type.COMPOUND_REWRAP false;
}

tile across down x
    = oo_unary_function tile_op x, is_class x
    = vips_replicate [] x (to_real across) (to_real down), is_image x
    = error_bad_args "cache"
        ["real", "real", "Image"] [across, down, x]
{
    tile_op = Operator "tile" (tile across down)
        Operator_type.COMPOUND_REWRAP false;
}

grid options tile_height across down x
    = oo_unary_function grid_op x, is_class x
    = vips_grid options x (to_real tile_height) (to_real across) (to_real down),
        is_image x
    = error_bad_args "grid"
        ["real", "real", "real", "Image"] [tile_height, across, down, x]
{
    grid_op = Operator "grid" (grid options tile_height across down)
        Operator_type.COMPOUND_REWRAP false;
}

transpose3d options x
    = oo_unary_function transpose3d_op x, is_class x
    = vips_transpose3d options x, is_image x
    = error (_ "bad arguments to " ++ "transpose3d")
{
    transpose3d_op = Operator "transpose3d" (transpose3d options)
        Operator_type.COMPOUND_REWRAP false;
}

max x
    = oo_unary_function max_op x, is_class x
    = vips_max [] x, is_image x
    = max_list x, is_list x
    = x, is_number x
    = error_bad_args "max" ["Image|Matrix"] [x]
{
    max_op = Operator "max" max Operator_type.COMPOUND false;

    max_list [] = error "max []";
    max_list x
        = foldr1 maxpair x, is_real_list x
        = foldr1 maxpair (map max_list x), is_list x
        = max x;
}

min x
    = oo_unary_function min_op x, is_class x
    = vips_min [] x, is_image x
    = min_list x, is_list x
    = x, is_number x
    = error_bad_args "min" ["Image|Matrix"] [x]
{
    min_op = Operator "min" min Operator_type.COMPOUND false;

    min_list [] = error "min []";
    min_list x
        = foldr1 minpair x, is_real_list x
        = foldr1 minpair (map min_list x), is_list x
        = min x;
}

maxpos x
    = oo_unary_function maxpos_op x, is_class x
    = maxpos_im x, is_image x
    = maxpos_matrix x, is_matrix x
    = maxpos_list x, is_list x
    = error_bad_args "maxpos" ["Image|Matrix"] [x]
{
    maxpos_op = Operator "maxpos" maxpos Operator_type.COMPOUND false;

    maxpos_matrix [[]] = (-1, -1);
    maxpos_matrix m
        = (indexes?row, row)
    {
        max_value = max (Matrix m);
        indexes = map (index (equal max_value)) m;
        row = index (not_equal (-1)) indexes;
    }

    maxpos_list [] = -1;
    maxpos_list l = index (equal (max l)) l;

    maxpos_im i
        = (x, y)
     {
        [value, x, y] = vips_max [$x => true, $y => true] i;
     }
}

minpos x
    = oo_unary_function minpos_op x, is_class x
    = minpos_im x, is_image x
    = minpos_matrix x, is_matrix x
    = minpos_list x, is_list x
    = error_bad_args "minpos" ["Image|Matrix"] [x]
{
    minpos_op = Operator "minpos" minpos Operator_type.COMPOUND false;

    minpos_matrix [[]] = (-1, -1);
    minpos_matrix m
        = (indexes?row, row)
    {
        min_value = min (Matrix m);
        indexes = map (index (equal min_value)) m;
        row = index (not_equal (-1)) indexes;
    }

    minpos_list [] = -1;
    minpos_list l = index (equal (min l)) l;

    minpos_im i
        = (x, y)
     {
        [value, x, y] = vips_min [$x => true, $y => true] i;
     }
}

stats x
    = oo_unary_function stats_op x, is_class x
    = to_matrix (vips_stats [] x), is_image x
    = to_matrix (vips_stats [] (to_image x)), is_matrix x
    = error_bad_args "stats" ["Image|Matrix"] [x]
{
    stats_op = Operator "stats" stats Operator_type.COMPOUND false;
}

e = 2.7182818284590452354;

pi = 3.14159265358979323846;

rad d = 2 * pi * (d / 360);

deg r = 360 * r / (2 * pi);

sign x
    = oo_unary_function sign_op x, is_class x
    = vips_sign [] x, is_image x
    = sign_cmplx x, is_complex x
    = sign_num x, is_real x
    = error_bad_args "sign" ["Image|Matrix"] [x]
{
    sign_op = Operator "sign" sign Operator_type.COMPOUND_REWRAP false;

    sign_num n
        = 0, n == 0
        = 1, n > 0
        = -1;

    sign_cmplx c
        = (0, 0), mod == 0
        = (re c / mod, im c / mod)
    {
        mod = abs c;
    }
}

rint x
    = oo_unary_function rint_op x, is_class x
    = vips_round [] x "rint", is_image x
    = rint_value x, is_number x
    = error_bad_args "rint" ["Image|real"] [x]
{
    rint_op = Operator "rint" rint Operator_type.ARITHMETIC false;

    rint_value x
        = (int) (x + 0.5), x > 0
        = (int) (x - 0.5);
}

scale x
    = oo_unary_function scale_op x, is_class x
    = (unsigned char) x, is_number x
    = vips_scale [] x, is_image x
    = scale_list x, is_real_list x || is_matrix x
    = error_bad_args "scale" ["Image|Matrix"] [x]
{
    scale_op = Operator "scale" scale Operator_type.COMPOUND_REWRAP false;

    scale_list l
        = apply_scale s o l
    {
        mn = find_limit minpair l;
        mx = find_limit maxpair l;
        s = 255.0 / (mx - mn);
        o = -(mn * s);
    }

    find_limit fn l
        = find_limit fn (map (find_limit fn) l), is_listof is_list l
        = foldr1 fn l;

    apply_scale s o x
        = x * s + o, is_number x
        = map (apply_scale s o) x;
}

scaleps x
    = oo_unary_function scale_op x, is_class x
    = vips_scale [$log => true] x, is_image x
    = error_bad_args "scaleps" ["Image"] [x]
{
    scale_op = Operator "scaleps" scaleps Operator_type.COMPOUND_REWRAP false;
}

fwfft x
    = oo_unary_function fwfft_op x, is_class x
    = vips_fwfft [] x, is_image x
    = error_bad_args "fwfft" ["Image"] [x]
{
    fwfft_op = Operator "fwfft" fwfft Operator_type.COMPOUND_REWRAP false;
}

invfft x
    = oo_unary_function invfft_op x, is_class x
    = vips_invfft [$real => true] x, is_image x
    = error_bad_args "invfft" ["Image"] [x]
{
    invfft_op = Operator "invfft" invfft Operator_type.COMPOUND_REWRAP false;
}

falsecolour x
    = oo_unary_function falsecolour_op x, is_class x
    = vips_falsecolour [] x, is_image x
    = error_bad_args "falsecolour" ["Image"] [x]
{
    falsecolour_op = Operator "falsecolour" falsecolour
        Operator_type.COMPOUND_REWRAP false;
}

polar x
    = oo_unary_function polar_op x, is_class x
    = vips_complex [] x $polar, is_image x
    = polar_cmplx x, is_complex x
    = error_bad_args "polar" ["Image|complex"] [x]
{
    polar_op = Operator "polar" polar Operator_type.COMPOUND false;

    polar_cmplx (x, y)
        = (l, a)
    {
        a
            = 270, x == 0 && y < 0
            = 90, x == 0 && y >= 0
            = 360 + atan (y / x), x > 0 && y < 0
            = atan (y / x), x > 0 && y >= 0
            = 180 + atan (y / x);

        l = (x ** 2 + y ** 2) ** 0.5;
    }
}

rectangular x
    = oo_unary_function rectangular_op x, is_class x
    = vips_complex [] x $rect, is_image x
    = rectangular_cmplx x, is_complex x
    = error_bad_args "rectangular" ["Image|complex"] [x]
{
    rectangular_op = Operator "rectangular" rectangular
        Operator_type.COMPOUND false;

    rectangular_cmplx (l, a) = (l * cos a, l * sin a);
}

// we can't use colour_unary: that likes 3 band only
recomb matrix x
    = oo_unary_function recomb_op x, is_class x
    = vips_recomb [] x matrix, is_image x
    = recomb_real_list x, is_real_list x
    = map recomb_real_list x, is_matrix x
    = error_bad_args "recomb"
        ["Matrix", "Image|Vector|Matrix"] [matrix, x]
{
    // COMPOUND_REWRAP ... signal to the colour class to go to image and
    // back
    recomb_op = Operator "recomb" (recomb matrix)
        Operator_type.COMPOUND_REWRAP false;

    // process [1,2,3 ..] as an image
    recomb_real_list l
        = (to_matrix im').value?0
    {
        im = (float) (to_image (Vector l)).value;
        im' = recomb matrix im;
    }
}

crop x y w h obj
    = oo_unary_function crop_op obj, is_class obj
    = vips_crop [] obj x' y' w' h', is_image obj
    = map (crop_range x' w') (crop_range y' h' obj), is_matrix obj
    = error_bad_args "crop"
        ["real", "real", "real", "real", "Image|Matrix"]
        [x, y, w, h, obj]
{
    x' = to_real x;
    y' = to_real y;
    w' = to_real w;
    h' = to_real h;

    crop_op = Operator "crop" (crop x y w h) Operator_type.COMPOUND_REWRAP false;

    crop_range from length list = (take length @ drop from) list;
}

extract_band b obj = subscript obj b;

extract_row y obj
    = oo_unary_function extract_row_op obj, is_class obj
    = crop 0 y' (get_width obj) 1 obj, is_image obj
    = [obj?y'], is_matrix obj
    = error_bad_args "extract_row" ["real", "Image|Matrix"] [y, obj]
{
    y' = to_real y;

    extract_row_op = Operator "extract_row" (extract_row y)
        Operator_type.COMPOUND_REWRAP false;
}

extract_column x obj
    = oo_unary_function extract_column_op obj, is_class obj
    = crop x' 0 1 height obj, is_image obj
    = map (\row [row?x']) obj, is_matrix obj
    = error_bad_args "extract_column" ["real", "Image|Matrix"] [x, obj]
{
    x' = to_real x;
    height = get_header "Ysize" obj;

    extract_column_op = Operator "extract_column" (extract_column x)
        Operator_type.COMPOUND_REWRAP false;
}

blend cond in1 in2
    = oo_binary_function blend_op cond [in1, in2], is_class cond
    = vips_ifthenelse [$blend => true]
        (get_image cond) (get_image in1) (get_image in2),
            has_image cond && has_image in1 && has_image in2
    = error_bad_args "blend"
        ["Image", "Image|constant", "Image|constant"] [cond, in1, in2]
{
    blend_op = Operator "blend" blend_obj
        Operator_type.COMPOUND_REWRAP false;

    blend_obj cond x
        = blend_result_image
    {
        [then_part, else_part] = x;

        // get things about our output from inputs in this order
        objects = [then_part, else_part, cond];

        // properties of our output image
        target_width = get_member_list has_width get_width objects;
        target_height = get_member_list has_height get_height objects;
        target_bands = get_member_list has_bands get_bands objects;
        target_format = get_member_list has_format get_format objects;
        target_interpretation
            = get_member_list has_interpretation get_interpretation objects;

        to_image x
            = to_image_size target_width target_height target_bands
                target_format x;

        [then_image, else_image] = map to_image [then_part, else_part];

        blend_result_image = copy [$interpretation => target_interpretation]
            (blend cond then_image else_image);
    }
}

insert options x y small big
    // do big first: we want to keep big's class, if possible
    // eg. big is a Plot, small is a 1x1 Image
    = oo_binary'_function insert_op small big, is_class big
    = oo_binary_function insert_op small big, is_class small
    = vips_insert options big small (to_real x) (to_real y),
        is_image small && is_image big
    = error_bad_args "insert"
        ["[option]", "real", "real", "Image", "Image"]
        [options, x, y, small, big]
{
    insert_op = Operator "insert" (insert options x y)
        Operator_type.COMPOUND_REWRAP false;
}

decode im
    = oo_unary_function decode_op im, is_class im
    = decode_im im, is_image im
    = error_bad_args "decode" ["Image"] [im]
{
    decode_op = Operator "decode" decode
        Operator_type.COMPOUND_REWRAP false;

    decode_im im
        = vips_LabQ2Lab [] im, get_coding im == Coding.LABPACK
        = vips_rad2float [] im, get_coding im == Coding.RAD
        = im;
}

measure_draw across down measure image
    = mark
{
    patch_width = image.width / across;
    sample_width = patch_width * (measure / 100);
    left_margin = (patch_width - sample_width) / 2;
    patch_height = image.height / down;
    sample_height = patch_height * (measure / 100);
    top_margin = (patch_height - sample_height) / 2;

    cods = [[x * patch_width + left_margin, y * patch_height + top_margin] ::
        y <- [0 .. down - 1]; x <- [0 .. across - 1]];
    x = map (extract 0) cods;
    y = map (extract 1) cods;

    outer = Image (image_new [$pixel => 255] sample_width sample_height);
    inner = Image (image_new [] (sample_width - 4) (sample_height - 4));
    patch = insert [] 2 2 inner outer;

    bg = Image (image_new [] image.width image.height);

    mask = Image (insertset bg.value patch.value x y);

    image' = colourspace [] $srgb image;

    mark = if mask then Vector [0, 255, 0] else image';

    insertset main sub x y
          = foldr add_another main (zip2 x y)
    {
          add_another [x, y] im = insert [] x y sub im;
    }
}

measure_sample across down measure image
    = measures
{
    patch_width = image.width / across;
    sample_width = patch_width * (measure / 100);
    left_margin = (patch_width - sample_width) / 2;
    patch_height = image.height / down;
    sample_height = patch_height * (measure / 100);
    top_margin = (patch_height - sample_height) / 2;

    cods = [[x * patch_width + left_margin, y * patch_height + top_margin] ::
        y <- [0 .. down - 1]; x <- [0 .. across - 1]];

    image' = decode image;
    patches = map (\[x, y] crop x y sample_width sample_height image') cods;
    measures = Matrix (map (map mean) (map bandsplit patches));
}

extract_bands b n obj
    = oo_unary_function extract_bands_op obj, is_class obj
    = vips_extract_band [$n => to_real n] obj (to_real b), is_image obj
    = error_bad_args "extract_bands" ["real", "real", "Image"] [b, n, obj]
{
    extract_bands_op = Operator "extract_bands" (extract_bands b n)
        Operator_type.COMPOUND_REWRAP false;
}

invert x
    = oo_unary_function invert_op x, is_class x
    = vips_invert [] x, is_image x
    = 255 - x, is_real x
    = error_bad_args "invert" ["Image|real"] [x]
{
    invert_op = Operator "invert" invert Operator_type.COMPOUND false;
}

transform options params image
    = oo_unary_function transform_op image, is_class image
    = vips_quadratic options image (to_matrix params), is_image image
    = error_bad_args "transform"
        ["[option]", "Matrix", "Image"] [options, params, image]
{
    transform_op = Operator "transform" (transform options params)
        Operator_type.COMPOUND_REWRAP false;
}

rotate options angle x
    = oo_unary_function rotate_op x, is_class x
    = vips_rotate options x (to_real angle), is_image x
    = error_bad_args "rotate"
        ["[option]", "real", "Image"] [options, angle, x]
{
    rotate_op = Operator "rotate" (rotate options angle)
        Operator_type.COMPOUND_REWRAP false;
}

joinlr a b
    = oo_binary_function joinlr_op a b, is_class a
    = oo_binary'_function joinlr_op a b, is_class b
    = joinlr_im a b, is_image a && is_image b
    = apply_matim_binary joinlr_im a b, is_matrix_image a && is_matrix_image b
    = error_bad_args "joinlr" ["Image", "Image"] [a, b]
{
    joinlr_op = Operator "joinlr" joinlr Operator_type.COMPOUND_REWRAP false;

    joinlr_im a b = insert [$expand => true] (get_width a) 0 b a;
}

jointb a b
    = oo_binary_function jointb_op a b, is_class a
    = oo_binary'_function jointb_op a b, is_class b
    = jointb_im a b, is_image a && is_image b
    = apply_matim_binary jointb_im a b, is_matrix_image a && is_matrix_image b
    = error_bad_args "jointb" ["Image", "Image"] [a, b]
{
    jointb_op = Operator "jointb" jointb Operator_type.COMPOUND_REWRAP false;

    jointb_im a b = insert [$expand => true] 0 (get_height a) b a;
}

conj x
    = oo_unary_function conj_op x, is_class x
    = (re x, -im x),
        is_complex x ||
        (is_image x && format == Format.COMPLEX) ||
        (is_image x && format == Format.DPCOMPLEX)
    // assume it's some sort of real
    = x
{
    format = get_header "format" x;
    conj_op = Operator "conj" conj Operator_type.COMPOUND false;
}

cast format x
    = oo_unary_function cast_op x, is_class x
    = vips_cast [] x (to_real format), is_image x
    = cast_real (to_real format) x, is_real x
    = error_bad_args "cast" ["Format", "Image"] [format, x]
{
    cast_op = Operator "cast" (cast format)
        Operator_type.COMPOUND_REWRAP false;

    cast_real format x
        = cast_unsigned_char x, format == Format.UCHAR
        = cast_signed_char x, format == Format.CHAR
        = cast_unsigned_short x, format == Format.USHORT
        = cast_signed_short x, format == Format.SHORT
        = cast_unsigned_int x, format == Format.UINT
        = cast_signed_int x, format == Format.INT
        = cast_float x, format == Format.FLOAT
        = cast_double x, format == Format.DOUBLE
        = cast_complex x, format == Format.COMPLEX
        = cast_double_complex x, format == Format.DPCOMPLEX
        = error (_ "bad arguments to " ++ "cast");
}

embed options x y w h im
    = oo_unary_function embed_op im, is_class im
    = vips_embed options im
        (to_real x) (to_real y) (to_real w) (to_real h), is_image im
    = error_bad_args "embed"
        ["[option]", "real", "real", "real", "real", "Image"]
        [options, x, y, w, h, im]
{
    embed_op = Operator "embed" (embed options x y w h)
        Operator_type.COMPOUND_REWRAP false;
}

/* Morph a mask with a [[real]] matrix ... turn m2 into an image, morph it
 * with m1, turn it back to a matrix again.
 */
_morph_2_masks fn m1 m2
    = m''
{
    // The [[real]] can contain 128 values ... squeeze them out!
    image = vips_image_from_matrix (Matrix m2) == 255;
    m2_width = get_width image;
    m2_height = get_height image;

    // need to embed m2 in an image large enough for us to be able to
    // position m1 all around the edges, with a 1 pixel overlap
    image' = embed []
        (m1.width / 2) (m1.height / 2)
        (m2_width + (m1.width - 1)) (m2_height + (m1.height - 1))
        image;

    // morph!
    image'' = fn m1 image';

    // back to mask
    m' = vips_matrix_from_image ((double) image'');

    // Turn 0 in output to 128 (don't care).
    m''
        = map (map fn) m'.value
    {
        fn a
            = 128, a == 0;
            = a;
    }
}

dilate mask image
    = oo_unary_function dilate_op image, is_class image
    = vips_morph [] image (to_matrix mask) "dilate", is_image image
    = error_bad_args "dilate" ["Matrix", "Image"] [mask, image]
{
    dilate_op = Operator "dilate" dilate_object
        Operator_type.COMPOUND_REWRAP false;

    dilate_object x
        = _morph_2_masks dilate mask x, is_matrix x
        = dilate mask x;
}

erode mask image
    = oo_unary_function erode_op image, is_class image
    = vips_morph [] image (to_matrix mask) "erode", is_image image
    = error_bad_args "erode" ["Matrix", "Image"] [mask, image]
{
    erode_op = Operator "erode" erode_object
        Operator_type.COMPOUND_REWRAP false;

    erode_object x
        = _morph_2_masks erode mask x, is_matrix x
        = erode mask x;
}

conv options mask image
    = oo_unary_function conv_op image, is_class image
    = vips_conv options image (to_matrix mask), is_image image
    = error_bad_args "conv"
        ["[option]", "Matrix", "Image"] [options, mask, image]
{
    conv_op = Operator "conv" (conv options mask)
        Operator_type.COMPOUND_REWRAP false;
}

convsep options mask image
    = oo_unary_function convsep_op image, is_class image
    = vips_convsep options image (to_matrix mask), is_image image
    = error_bad_args "convsep"
        ["[option]", "Matrix", "Image"] [options, mask, image]
{
    convsep_op = Operator "convsep" (convsep options mask)
        Operator_type.COMPOUND_REWRAP false;
}

rank w h n image
    = oo_unary_function rank_op image, is_class image
    = vips_rank [] image (to_real w) (to_real h) (to_real n), is_image image
    = error_bad_args "rank" ["real", "real", "real", "Image"] [w, h, n, im]
{
    rank_op = Operator "rank" (rank w h n) Operator_type.COMPOUND_REWRAP false;
}

rank_image n x
    = rlist x.value, is_Group x
    = rlist x, is_list x
    = error_bad_args "rank_image" ["real", "[Image]|Group"] [n, x]
{
    rlist l
        = wrapper ranked, has_wrapper
        = ranked
    {
        has_wrapper = has_member_list (has_member "Image") l;
        wrapper = get_member_list (has_member "Image") (get_member "Image") l;
        ranked = vips_bandrank [$index => to_real n] (map get_image l);
    }
}

// find the correlation surface for a small image within a big one
correlate small big
    = oo_binary_function correlate_op small big, is_class small
    = oo_binary'_function correlate_op small big, is_class big
    = vips_spcor [] big small, is_image small && is_image big
    = error_bad_args "correlate" ["Image", "Image"] [small, big]
{
    correlate_op = Operator "correlate" correlate
        Operator_type.COMPOUND_REWRAP false;
}

// just sum-of-squares-of-differences
correlate_fast small big
    = oo_binary_function correlate_fast_op small big, is_class small
    = oo_binary'_function correlate_fast_op small big, is_class big
    = vips_fastcor [] big small, is_image small && is_image big
    = error_bad_args "correlate_fast" ["Image", "Image"] [small, big]
{
    correlate_fast_op = Operator "correlate_fast" correlate_fast
        Operator_type.COMPOUND_REWRAP false;
}

// set interpretation, wrap as Plot_hist if it's a class
hist_tag x
    = oo_unary_function hist_tag_op x, is_class x
    = set_header $interpretation $histogram x, is_image x
    = error_bad_args "hist_tag" ["Image"] [x]
{
    hist_tag_op = Operator "hist_tag" (Plot_histogram @ hist_tag)
        Operator_type.COMPOUND false;
}

hist_find x
    = oo_unary_function hist_find_op x, is_class x
    = vips_hist_find [] x, is_image x
    = error_bad_args "hist_find" ["Image"] [x]
{
    hist_find_op = Operator "hist_find" (Plot_histogram @ hist_find)
        Operator_type.COMPOUND false;
}

hist_find_nD bins image
    = oo_unary_function hist_find_nD_op image, is_class image
    = vips_hist_find_ndim [$bins => to_real bins] image, is_image image
    = error_bad_args "hist_find_nD" ["real", "Image"] [bins, image]
{
    hist_find_nD_op = Operator "hist_find_nD" (hist_find_nD bins)
        Operator_type.COMPOUND_REWRAP false;
}

hist_find_indexed options index value
    = oo_binary_function hist_find_indexed_op index value, is_class index
    = oo_binary'_function hist_find_indexed_op index value, is_class value
    = vips_hist_find_indexed options value index,
        is_image index && is_image value
    = error_bad_args "hist_find_indexed"
        ["[option]", "Image", "Image"] [options, index, value]
{
    hist_find_indexed_op = Operator "hist_find_indexed"
        (compose (compose Plot_histogram) (hist_find_indexed options))
            Operator_type.COMPOUND false;
}

hist_entropy x
    = oo_unary_function hist_entropy_op x, is_class x
    = vips_hist_entropy [] x, is_image x
    = error_bad_args "hist_entropy" ["Image"] [image]
{
    hist_entropy_op = Operator "hist_entropy" hist_entropy
        Operator_type.COMPOUND_REWRAP false;
}

maplut options hist image
    = oo_binary_function maplut_op hist image, is_class hist
    = oo_binary'_function maplut_op hist image, is_class image
    = vips_maplut options image hist, is_image hist && is_image image
    = error_bad_args "maplut"
        ["[option]", "Image", "Image"] [options, hist, image]
{
    // can't use rewrap, as we want to always wrap as image
    maplut_op = Operator "maplut" (compose (compose Image) (maplut options))
        Operator_type.COMPOUND false;
}

hist_cum hist
    = oo_unary_function hist_cum_op hist, is_class hist
    = vips_hist_cum [] hist, is_image hist
    = error_bad_args "hist_cum" ["Image"] [hist]
{
    hist_cum_op = Operator "hist_cum" hist_cum
        Operator_type.COMPOUND_REWRAP false;
}

hist_diff hist
    = oo_unary_function hist_diff_op hist, is_class hist
    = hist_diff_im hist, is_image hist
    = error_bad_args "hist_diff" ["Image"] [hist]
{
    hist_diff_op = Operator "hist_diff" hist_diff
        Operator_type.COMPOUND_REWRAP false;

    hist_diff_im h
        = (conv [] (Matrix [[-1, 1]]) @ cast (fmt (get_format h))) h
    {
        // up the format so it can represent the whole range of
        // possible values from this mask
        fmt x
            = Format.SHORT,
                x == Format.UCHAR || x == Format.CHAR
            = Format.INT,
                x == Format.USHORT || x == Format.SHORT || x == Format.UINT
            = x;
    }
}

hist_norm hist
    = oo_unary_function hist_norm_op hist, is_class hist
    = vips_hist_norm [] hist, is_image hist
    = error_bad_args "hist_norm" ["Image"] [hist]
{
    hist_norm_op = Operator "hist_norm" hist_norm
        Operator_type.COMPOUND_REWRAP false;
}

hist_inv hist
    = oo_unary_function hist_inv_op hist, is_class hist
    = inv hist, is_image hist
    = error_bad_args "hist_inv" ["Image"] [hist]
{
    hist_inv_op = Operator "hist_inv" hist_inv
        Operator_type.COMPOUND_REWRAP false;

    inv im
        = vips_invertlut [$size => len] (to_matrix im''')
    {
        // need a vertical doublemask
        im'
            = rot90 im, get_width im > 1 && get_height im == 1
            = im, get_width im == 1 && get_height im > 1
            = error (_ "not a hist");
        len = get_height im';

        // values must be scaled to 0 - 1
        im'' = im' / (max im');

        // add an index column on the left
        // again, must be in 0-1
        y = ((xyz [] 1 len)?1) / len;
        im''' = y ++ im'';
    }
}

hist_match in ref
    = oo_binary_function hist_match_op in ref, is_class in
    = oo_binary'_function hist_match_op in ref, is_class ref
    = vips_hist_match [] in' ref', is_image in && is_image ref
    = error_bad_args "hist_match" ["Image", "Image"] [in, ref]
{
    hist_match_op = Operator "hist_match" hist_match
        Operator_type.COMPOUND_REWRAP false;

    in' = (hist_norm @ hist_cum) in;
    ref' = (hist_norm @ hist_cum) ref;
}

hist_equalize x = maplut [] ((hist_norm @ hist_cum @ hist_find) x) x;

hist_equalize_local options w h image
    = oo_unary_function hist_equalize_local_op image, is_class image
    = vips_hist_local options image (to_real w) (to_real h), is_image image
    = error_bad_args "hist_equalize_local"
        ["[option]", "real", "real", "Image"] [options, w, h, image]
{
    hist_equalize_local_op = Operator "hist_equalize_local"
        (hist_equalize_local options w h)
        Operator_type.COMPOUND_REWRAP false;
}

// find the threshold below which are percent of the image (percent in [0,1])
// eg. hist_thresh 0.1 x == 12, then x < 12 will light up 10% of the pixels
hist_thresh percent image
    = x
{
    // our own normaliser ... we don't want to norm channels separately
    // norm to [0,1]
    my_hist_norm h = h / max h;

    // normalised cumulative hist
    // we sum the channels before we normalise, because we want to treat them
    // all the same
    h = (my_hist_norm @ sum @ bandsplit @ hist_cum @ hist_find) image.value;

    // threshold that, then use profile to search for the x position in the
    // histogram
    x = mean (vips_profile [] (h > percent))?1;
}

