
Colour_new_item = class
    Menupullright (_ "New") (_ "make a patch of colour") {
    Widget_colour_item = class
        Menuaction (_ "Colour") (_ "make a patch of colour") {
        action = Colour_picker "LAB" [50,0,0];
    }

    sep1 = Menuseparator;

    LAB_colour = class
        Menuaction (_ "CIE Lab Picker") (_ "pick colour in CIE Lab space") {
        action = widget "LAB" [50, 0, 0];

        // ab_slice size
        size = 512;

        // range of values ... +/- 128 for ab
        range = 256;

        // map xy in slice image to ab and back
        xy2ab x = x / (size / range) - 128;
        ab2xy a = (a + 128) * (size / range);

        widget space default_value = class
            Colour space _result {
            _vislevel = 3;

            [_L, _a, _b] = default_value;
            L = Scale "Lightness" 0 100 _L;
            ab_slice = Image (lab_slice size L.value);
            point = Mark ab_slice (ab2xy _a) (ab2xy _b);

            _result = [L.value, xy2ab point.left, xy2ab point.top];

            Colour_edit colour_space value = widget colour_space value;
        }
    }

    CCT_colour = class
        Menuaction (_ "Colour from CCT") (_ "pick colour by CCT") {
        action = widget 6500;

        widget x = class
            _result {
            _vislevel = 3;

            T = Scale "CCT" 1800 25000 x;

            _result = colour_from_temp (to_real T);

            Colour_edit space value
                = widget (temp_from_colour (Colour space value));
        }
    }
}

Colour_to_colour_item = class
    Menuaction (_ "Convert to Colour") (_ "convert anything to a Colour") {
    action x = to_colour x;
}

#separator

Colour_convert_item = class
    Menupullright (_ "Colourspace") (_ "convert between colour spaces") {
    conv dest x = class
        _result {
        _vislevel = 3;

        to = Interpretation_nary.picker (Interpretation.get_key dest);

        _result = map_unary (colourspace [] to.value_key) x;
    }

    Mono_item = class
        Menuaction (_ "Mono, 8-bit") (_ "convert to mono colourspace") {
        action x = conv Interpretation.B_W x;
    }

    GREY16_item = class
        Menuaction (_ "Mono, 16-bit") (_ "convert to GREY16 colourspace") {
        action x = conv Interpretation.GREY16 x;
    }

    scRGB_item = class
        Menuaction (_ "_scRGB") (_ "convert to scRGB colourspace") {
        action x = conv Interpretation.scRGB x;
    }

