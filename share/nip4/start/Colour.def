Colour_dE_item = class
    Menupullright (_ "Difference") (_ "calculate colour difference") {
    CIEdE76_item = class
        Menuaction (_ "CIE dE 1976")
            (_ "calculate CIE dE 1976 for two objects") {
        action a b = map_binary dE76 a b;
    }

    CIEdE00_item = class
        Menuaction (_ "CIE dE 2000")
            (_ "calculate CIE dE 2000 for two objects") {
        action a b = map_binary dE00 a b;
