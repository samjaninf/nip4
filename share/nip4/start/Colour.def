        Menuaction (_ "_sRGB, 8-bit") (_ "convert to sRGB colourspace") {
        action x = conv Interpretation.sRGB x;
    }

    RGB16_item = class
        Menuaction (_ "sRGB, 16-bit") (_ "convert to RGB16 colourspace") {
        action x = conv Interpretation.RGB16 x;
    }

    HSV_item = class
        Menuaction (_ "HSV") (_ "convert to HSV colourspace") {
        action x = conv Interpretation.HSV x;
    }

    XYZ_item = class
        Menuaction (_ "_XYZ") (_ "convert to XYZ colourspace") {
        action x = conv Interpretation.XYZ x;
    }

    Yxy_item = class
        Menuaction (_ "_Yxy") (_ "convert to Yxy colourspace") {
        action x = conv Interpretation.YXY x;
    }

    Lab_item = class
        Menuaction (_ "_Lab") (_ "convert to Lab colourspace (float Lab)") {
        action x = conv Interpretation.LAB x;
    }

    OKLab_item = class
        Menuaction (_ "OKLab") (_ "convert to OKLab colourspace") {
        action x = conv Interpretation.OKLAB x;
    }

    LabQ_item = class
        Menuaction (_ "LabQ") (_ "convert to LabQ colourspace (32-bit Lab)") {
        action x = conv Interpretation.LABQ x;
    }

    LabS_item = class
        Menuaction (_ "LabS") (_ "convert to LabS colourspace (48-bit Lab)") {
        action x = conv Interpretation.LABS x;
    }

    LCh_item = class
        Menuaction (_ "LCh") (_ "convert to LCh colourspace") {
