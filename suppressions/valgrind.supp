# vulkan / nouveau strangeness

{
   vk-enumerate
   Memcheck:Leak
   match-leak-kinds: possible
   fun:*alloc
   obj:/usr/lib/x86_64-linux-gnu/libvulkan_nouveau.so
   ...
   fun:vkEnumeratePhysicalDevices
}

{
   vk-enumerate3
   Memcheck:Leak
   match-leak-kinds: possible
   fun:*alloc
   obj:/usr/lib/x86_64-linux-gnu/libvulkan_lvp.so
   ...
   fun:vkEnumeratePhysicalDevices
}

{
   vk-create
   Memcheck:Leak
   match-leak-kinds: possible
   fun:*alloc
   obj:/usr/lib/x86_64-linux-gnu/libvulkan_lvp.so
   ...
   fun:vkCreateInstance
}

{
   vk-create2
   Memcheck:Leak
   match-leak-kinds: possible
   fun:*alloc
   obj:/usr/lib/x86_64-linux-gnu/libvulkan_nouveau.so
   ...
   fun:vkCreateInstance
}

{
   vk-create3
   Memcheck:Leak
   match-leak-kinds: possible
   fun:*alloc
   obj:/usr/lib/x86_64-linux-gnu/libVkLayer_MESA_device_select.so
   ...
   fun:vkCreateInstance
}

{
   vk-create5
   Memcheck:Leak
