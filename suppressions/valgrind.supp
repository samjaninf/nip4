# various nvidia wtfs

{
   nv1
   Memcheck:ReallocZero
   fun:realloc
   ...
   fun:NvGlEglApiInit
}

{
   nv2
   Memcheck:BadSize
   fun:posix_memalign
   ...
   fun:NvGlEglApiInit
}

{
   nv3
   Memcheck:Param
   write(buf)
   fun:__libc_write
   fun:write
   obj:/usr/lib/x86_64-linux-gnu/libnvidia-egl-wayland.so.1.1.15
   ...
   fun:gdk_surface_ensure_egl_surface
}

{
   nv4
   Memcheck:Param
   write(buf)
   fun:__libc_write
   fun:write
   ...
   fun:gdk_gl_context_real_end_frame
}

{
   nv5
   Memcheck:Param
   write(buf)
   fun:__libc_write
   fun:write
   ...
   fun:gdk_surface_set_egl_native_window
}

