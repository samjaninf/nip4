{
    "app-id" : "org.libvips.nip4",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "nip4",
    "finish-args" : [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--talk-name=org.gtk.vfs.*",
        "--filesystem=xdg-run/gvfsd",
        "--filesystem=host"
    ],
    "cleanup" : [
        "/include",

        "/bin/Magick++-config",
        "/bin/MagickCore-config",
        "/bin/MagickWand-config",
        "/bin/animate",
        "/bin/compare",
        "/bin/composite",
        "/bin/conjure",
        "/bin/convert",
        "/bin/cookbook",
        "/bin/dcm-dump",
        "/bin/dcm-getframe",
        "/bin/display",
        "/bin/exr2aces",
        "/bin/exrenvmap",
        "/bin/exrheader",
        "/bin/exrinfo",
        "/bin/exrmakepreview",
        "/bin/exrmaketiled",
        "/bin/exrmanifest",
        "/bin/exrmetrics",
        "/bin/exrmultipart",
        "/bin/exrmultiview",
        "/bin/exrstdattr",
        "/bin/fitscopy",
        "/bin/fitsverify",
        "/bin/fpack",
        "/bin/funpack",
        "/bin/identify",
        "/bin/imcopy",
        "/bin/import",
        "/bin/libdeflate-gunzip",
        "/bin/libdeflate-gzip",
        "/bin/magick-script",
        "/bin/mogrify",
        "/bin/montage",
        "/bin/ojph_compress",
        "/bin/ojph_expand",
        "/bin/openslide-quickhash1sum",
        "/bin/openslide-show-properties",
        "/bin/openslide-write-png",
        "/bin/slidetool",
        "/bin/smem",
        "/bin/snip",
        "/bin/speed",
        "/bin/stream",
        "/bin/vips",
        "/bin/vipsedit",
        "/bin/vipsheader",
        "/bin/vipsthumbnail",

        "/lib/lib*.a",
        "/lib/lib*.la",
        "/lib/ImageMagick-*",
        "/lib/cmake",
        "/lib/girepository-1.0",
        "/lib/libMagick++-7*",
        "/lib/pkgconfig",

        "/share/aclocal",
        "/share/doc",
        "/share/gir-1.0",
        "/share/man",
        "/share/pkgconfig",
        "/share/aclocal*",
        "/share/info"

    ],
    "modules" : [

        {
            "name" : "libdeflate",
            "builddir" : true,
            "buildsystem" : "cmake-ninja",
            "build-options" : {
                "config-opts" : [
                    "-DCMAKE_INSTALL_LIBDIR=lib"
                ]
            },
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/ebiggers/libdeflate.git",
                    "tag" : "v1.25",
                    "commit" : "c8c56a20f8f621e6a966b716b31f1dedab6a41e3"
                }
            ]
        },

        {
            "name" : "openjph",
            "builddir" : true,
            "buildsystem" : "cmake-ninja",
            "build-options" : {
                "config-opts" : [
                    "-DCMAKE_INSTALL_LIBDIR=lib"
                ]
            },
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/aous72/OpenJPH.git",
                    "tag" : "0.26.3",
                    "commit" : "cb6592af91fc1332d5381288c1b885372926c447"
                }
            ]
        },

        {
            "name" : "libimagequant",
            "builddir" : true,
            "buildsystem" : "meson",
            "config-opts" : [
                "--libdir=lib",
                "--buildtype=release"
            ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/lovell/libimagequant.git",
                    "tag" : "v2.4.1",
                    "commit" : "4e82d9492db228a7a2057c442f7a6eb40508a0eb"
                }
            ]
        },

        {
            "name" : "poppler-data",
            "builddir" : true,
            "buildsystem" : "cmake-ninja",
            "build-options" : {
                "config-opts" : [
                    "-DCMAKE_INSTALL_LIBDIR=lib"
                ]
            },
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://poppler.freedesktop.org/poppler-data-0.4.12.tar.gz",

                    "sha256" : "c835b640a40ce357e1b83666aabd95edffa24ddddd49b8daff63adb851cdab74"
                }
            ]
        },

        {
            "name" : "poppler-glib",
            "builddir" : true,
            "buildsystem" : "cmake-ninja",
            "config-opts" : [
                    "-DCMAKE_INSTALL_LIBDIR=lib",
                    "-DBUILD_CPP_TESTS=OFF",
                    "-DBUILD_GTK_TESTS=OFF",
                    "-DBUILD_MANUAL_TESTS=OFF",
                    "-DBUILD_QT5_TESTS=OFF",
                    "-DBUILD_QT6_TESTS=OFF",
                    "-DENABLE_LIBTIFF=ON",
                    "-DENABLE_LIBPNG=ON",
                    "-DENABLE_GLIB=ON",
                    "-DENABLE_LIBOPENJPEG='openjpeg2'",
                    "-DENABLE_DCTDECODER='libjpeg'",
                    "-DENABLE_BOOST=OFF",
                    "-DENABLE_UTILS=OFF",
                    "-DENABLE_QT5=OFF",
                    "-DENABLE_QT6=OFF",
                    "-DENABLE_CPP=OFF"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://poppler.freedesktop.org/poppler-26.03.0.tar.xz",

                    "sha256" : "8b3c5e2a9f2ab4c3ec5029f28af1b433c6b71f0d1e7b3997aa561cf1c0ca4ebe"
                }
            ]
        },

        {
            "name" : "imath",
            "builddir" : true,
            "buildsystem" : "cmake-ninja",
            "build-options" : {
                "config-opts" : [
                    "-DCMAKE_INSTALL_LIBDIR=lib"
                ]
            },
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/AcademySoftwareFoundation/Imath.git",
                    "tag" : "v3.2.2",
                    "commit" : "1e480d11cb98b032a2dece9b9a8730512effc7f6"
                }
            ]
        },

        {
            "name" : "openexr",
            "builddir" : true,
            "buildsystem" : "cmake-ninja",
            "build-options" : {
                "config-opts" : [
                    "-DCMAKE_INSTALL_LIBDIR=lib"
                ]
            },
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/AcademySoftwareFoundation/openexr.git",
                    "tag" : "v3.4.8",
                    "commit" : "adbd2a588b47b1f6d02557571d8e36a91084da8a"
                }
            ]
        },

        {
            "name" : "libultrahdr",
            "builddir" : true,
            "buildsystem" : "cmake-ninja",
            "build-options" : {
                "config-opts" : [
                    "-DCMAKE_INSTALL_LIBDIR=lib",
                    "-DUHDR_BUILD_BENCHMARK=OFF",
                    "-DUHDR_BUILD_DEPS=OFF",
                    "-DUHDR_BUILD_EXAMPLES=OFF",
                    "-DUHDR_BUILD_FUZZERS=OFF",
                    "-DUHDR_BUILD_JAVA=OFF",
                    "-DUHDR_BUILD_PACKAGING=OFF",
                    "-DUHDR_BUILD_TESTS=OFF",
                    "-DUHDR_ENABLE_GLES=OFF",
                    "-DUHDR_ENABLE_LOGS=OFF",
                    "-DUHDR_ENABLE_WERROR=OFF",
                    "-DUHDR_WRITE_ISO=ON",
                    "-DUHDR_WRITE_XMP=OFF"
                ]
            },
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/google/libultrahdr.git",
                    "commit" : "8cbc983d2f6c2171af5cbcdb8801102f83fe92ab"
                }
            ]
        },

        {
            "name" : "uthash",
            "buildsystem" : "simple",
            "build-commands" : [
                "install -D include/* /app/include"
            ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/troydhanson/uthash.git",
                    "commit" : "6d8573997c21f24c7e4ec9e48734b44f384170a1"
                }
            ]
        },

        {
            "name" : "libdicom",
            "builddir" : true,
            "buildsystem" : "meson",
            "config-opts" : [
                "--buildtype=release",
                "--libdir=lib",
                "-Dtests=false"
            ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/ImagingDataCommons/libdicom.git",
                    "tag" : "v1.2.1",
                    "commit" : "04bf7d4267943ae60b8f3dd0159f4f75e9825af8"
                }
            ]
        },

        {
            "name" : "openslide",
            "builddir" : true,
            "buildsystem" : "meson",
            "config-opts" : [
                "--libdir=lib",
                "--buildtype=release"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://github.com/openslide/openslide/releases/download/v4.0.0/openslide-4.0.0.tar.xz",
                    "sha256" : "cc227c44316abb65fb28f1c967706eb7254f91dbfab31e9ae6a48db6cf4ae562"
                }
            ]
        },

        {
            "name" : "cfitsio",
            "builddir" : true,
            "buildsystem" : "autotools",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/HEASARC/cfitsio.git",
                    "tag" : "cfitsio-4.6.3",
                    "commit" : "386e719ccc5e30ca497ec2df57c4ef1de5adbc3f"
                }
            ]
        },

        {
            "name" : "cgif",
            "buildsystem" : "meson",
            "config-opts" : [
                "--libdir=lib",
                "--buildtype=release"
            ],
            "builddir" : true,
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/dloebl/cgif.git",
                    "tag" : "v0.5.2",
                    "commit" : "48d28fe9f8c3a344b688bb10274447b6bb1bf0c2"
                }
            ]
        },

        {
            "name" : "libraw",
            "builddir" : true,
            "buildsystem" : "autotools",
            "config-opts" : [
                "--disable-examples",
                "--enable-openmp",
                "--enable-jpeg",
                "--enable-zlib",
                "--enable-lcms"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://www.libraw.org/data/LibRaw-0.22.1.tar.gz",
                    "sha256" : "a789dc4e2409e2901d93793a4e0b80c7b49d0d97cf6ad71c850eb7616acfd786"
                }
            ]
        },

        {
            "name" : "imagemagick",
            "builddir" : true,
            "buildsystem" : "autotools",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/ImageMagick/ImageMagick",
                    "tag" : "7.1.2-18",
                    "commit" : "d4e4b2b35a573fb7d96bc64ff1a417415bbe0f4c"
                }
            ]
        },

        {
            "name" : "libvips",
            "builddir" : true,
            "buildsystem" : "meson",
            "config-opts" : [
                "--libdir=lib",
                "-Dmodules=disabled"
            ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/libvips/libvips.git",
                    "commit" : "0e8946a77dc7efe3b6e3bb704d17a7adabeb32ca"
                }
            ]
        },

        {
            "name" : "libgsl",
            "builddir" : true,
            "buildsystem" : "autotools",
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://ftp.snt.utwente.nl/pub/software/gnu/gsl/gsl-2.8.tar.gz",
                    "sha256" : "6a99eeed15632c6354895b1dd542ed5a855c0f15d9ad1326c6fe2b2c9e423190"
                }
            ],
            "cleanup" : [
                "/bin"
            ]
        },

        {
            "name" : "nip4",
            "builddir" : true,
            "buildsystem" : "meson",
            "config-opts" : [
                "-Dflatpak=true"
            ],
            "sources" : [
                {
                    "type" : "git",
                    "url" : "https://github.com/jcupitt/nip4.git",
                    "commit" : "f68336d4f0518e99ebc8994d66099d6ddb70c92b"
                }
            ]
        }
    ]
}
