#!/usr/bin/env snip

image = image_new [] 1 1;
image_lab = colourspace [] Interpretation.LAB image;

main = unit_test [
    [point (256, 256) (lab_slice 513 54) == [54, 0, 0], "lab_slice"],
    [image_white image == Vector [255], "image_white"],
    [image_white image_lab == Colour "LAB" [100, 0, 0], "image_white LAB"],
    [abs (colour_from_temp 5500 - Colour "YXY" [50, 0.332, 0.341]) < 0.001,
        "colour_from_temp"],
    [temp_from_colour (colour_from_temp 5500) - 5500 < 10,
        "temp_from_colour"],
    [get_width image == 1 &&
        get_height image == 1 &&
        mean image == 0, "image_new"]

];
